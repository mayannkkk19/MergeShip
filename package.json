{
  "name": "mergeship",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "supabase db reset",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "sim:webhook": "tsx --env-file=.env.local scripts/sim-webhook.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@octokit/auth-app": "^7.1.1",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.0",
    "@types/three": "^0.184.1",
    "@upstash/redis": "^1.34.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.36.4",
    "framer-motion": "^11.0.0",
    "groq-sdk": "^0.9.1",
    "inngest": "^3.27.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.400.0",
    "next": "14.2.5",
    "postgres": "^3.4.5",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "three": "^0.184.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.2.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^2.1.5",
    "autoprefixer": "^10.0.1",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "smee-client": "^2.0.4",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,md,json,yml,yaml,css}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
